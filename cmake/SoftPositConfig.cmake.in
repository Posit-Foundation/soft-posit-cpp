@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Find dependencies
if(@SOFTPOSIT_QUAD@)
  find_dependency(quadmath)
endif()

# Include targets file
include("${CMAKE_CURRENT_LIST_DIR}/SoftPositTargets.cmake")

# Set variables
set(SOFTPOSIT_INCLUDE_DIRS "@PACKAGE_INCLUDE_INSTALL_DIR@")
set(SOFTPOSIT_LIBRARIES SoftPosit::softposit)
if(@BUILD_SHARED_LIBS@)
  set(SOFTPOSIT_SHARED_LIBRARIES SoftPosit::softposit_shared)
endif()

# Check if all required components are available
check_required_components(SoftPosit) 